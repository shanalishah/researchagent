# Copy this file to `secrets.toml` (same folder) and fill in real values.
# `secrets.toml` is gitignored — never commit real credentials.
# Reuse the same values you set in your GitHub repo Settings > Secrets.

# --- Cloudflare R2 (required: app downloads corpus.db + FAISS index at runtime) ---
R2_ACCESS_KEY_ID = ""
R2_SECRET_ACCESS_KEY = ""
R2_ENDPOINT = ""
R2_BUCKET = ""

# --- Semantic Scholar (used by the Moneyball impact scoring) ---
S2_API_KEY = ""

# Note: LLM provider keys (OpenAI / Gemini / Groq) are NOT set here —
# you enter them in the app's UI at runtime, or pick "Free Local Model".
