# Copy this file to `backend/.env` and fill in real values.
# `backend/.env` is gitignored (the repo's .gitignore ignores all .env files).
# These are the SAME values as your Streamlit secrets / GitHub repo secrets.
#
# The backend reads these at startup so the extracted pipeline can pull the
# corpus from Cloudflare R2 and query Semantic Scholar.

# --- Cloudflare R2 (required: corpus.db + FAISS index are downloaded from here) ---
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET=

# --- Semantic Scholar (Moneyball author-citation lookups) ---
S2_API_KEY=

# --- Optional: where to cache the downloaded corpus locally ---
# Defaults to a temp dir if unset. Set this to keep it between runs.
# CORPUS_DATA_DIR=C:\dev\researchagent\.corpus_cache
